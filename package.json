{
  "name": "workstream",
  "version": "0.2.0",
  "description": "A macOS desktop app that runs Claude Code sessions in the background while you watch Stremio, then surfaces Claude Code the moment a session finishes.",
  "main": "./out/main/index.js",
  "author": "jmartins2000",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:test": "VITE_UNLOCK_MEDIA=1 electron-vite dev",
    "dev:debug": "VITE_UNLOCK_MEDIA=1 STREMIO_DEBUG=1 electron-vite dev",
    "build": "npm run typecheck && node scripts/write-build-info.mjs && electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "package": "npm run build && electron-builder --mac",
    "package:local": "npm run build && electron-builder --mac --dir",
    "fetch:stremio": "node scripts/fetch-stremio-service.mjs",
    "postinstall": "node scripts/fetch-stremio-service.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.183",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@ghostery/adblocker-electron": "^2.18.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "22.19.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "playwright": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.3",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vitest": "^3.0.0"
  }
}
